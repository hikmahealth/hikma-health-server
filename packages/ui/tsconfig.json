{
  "extends": "@hikmahealth/typescript-config/react-library.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "ES2015",
    "moduleDetection": "auto",
    "moduleResolution": "Bundler",
    "strict": false,
    "resolveJsonModule": false,
    "allowJs": true,
    "rootDir": "./src",
    "paths": {
      "@/*": ["./*"],
      "@hikmahealth/ui/lib/*": ["./lib/*"],
      "@hikmahealth/ui/hooks/*": ["./hooks/*"],
      "@hikmahealth/ui/components/*": ["./components/ui/*"],
    },
  },
  "include": ["./src"],
  "exclude": ["node_modules", "dist"],
  "references": [
    {
      "path": "../eslint-config",
    },
    {
      "path": "../typescript-config",
    },
  ],
}
