{
  "include": ["*.ts", "**/*.ts"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "target": "ES6",
    "module": "NodeNext",

    /* Bundler mode */
    // "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "declaration": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
  },
}
