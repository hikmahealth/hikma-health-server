{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "hh-local-hub",
  "version": "0.1.0",
  "identifier": "com.hikmahealth.local-hub",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HH Hub",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDczODRDMTgwNDA3QTlCNkUKUldSdW0zcEFnTUdFYzUyQ213UWpPTzJhaEpkM2s5TmJReXp4VDN6UzE1Qlg1Z213amtpSUJPWGwK",
      "endpoints": [
        "https://github.com/hikmahealth/hikma-health-server/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
