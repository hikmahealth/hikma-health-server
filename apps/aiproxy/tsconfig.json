{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": [
      "node"
    ],
    "resolveJsonModule": true
  },
  "include": [
    "api/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "lib"
  ],
  "references": [
    {
      "path": "../../packages/utils/js"
    }
  ]
}
